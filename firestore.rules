rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: obtener el rol del usuario autenticado
    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }
    
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    
    function isMedico() {
      return request.auth != null && getUserRole() == 'medico';
    }
    
    function isMedicoOrAdmin() {
      return request.auth != null && (getUserRole() == 'admin' || getUserRole() == 'medico');
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // ============================================
    // USUARIOS — gestión de roles
    // ============================================
    match /usuarios/{uid} {
      // Cualquier autenticado puede leer su propio documento
      allow get: if isAuthenticated() && request.auth.uid == uid;
      // Admin puede leer y escribir todos los usuarios
      allow read: if isAdmin();
      allow write: if isAdmin();
      // Un usuario puede crear su propio documento (primer login)
      allow create: if isAuthenticated() && request.auth.uid == uid;
    }

    // ============================================
    // HISTORIAS CLÍNICAS — inmutables, solo médicos
    // ============================================
    match /historias_clinicas/{docId} {
      // Solo médicos y admin pueden leer historias clínicas
      allow read: if isMedicoOrAdmin();
      // Solo médicos y admin pueden crear (nunca editar ni eliminar)
      allow create: if isMedicoOrAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // NOTAS ACLARATORIAS — inmutables, solo médicos
    // ============================================
    match /notas_aclaratorias/{docId} {
      allow read: if isMedicoOrAdmin();
      allow create: if isMedicoOrAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // PACIENTES — protegidos
    // ============================================
    match /pacientes/{docId} {
      // Médicos y admin: acceso completo de lectura
      // Conductores: solo lectura básica (filtrado en la UI)
      allow read: if isAuthenticated();
      // Solo médicos y admin pueden crear pacientes
      allow create: if isMedicoOrAdmin();
      // Solo admin puede actualizar (datos no sensibles)
      allow update: if isAdmin()
        && request.resource.data.tipoDocumento == resource.data.tipoDocumento
        && request.resource.data.numeroDocumento == resource.data.numeroDocumento;
      // Nunca eliminar
      allow delete: if false;
    }

    // ============================================
    // AUDITORÍA DE PACIENTES — inmutable
    // ============================================
    match /paciente_auditoria/{docId} {
      allow read: if isAdmin();
      allow create: if isMedicoOrAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // ÓRDENES DE SERVICIO
    // ============================================
    match /ordenes_servicio/{docId} {
      allow read: if isAuthenticated();
      allow create: if isMedicoOrAdmin();
      allow update: if isMedicoOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // AMBULANCIAS
    // ============================================
    match /ambulancias/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isMedicoOrAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // TRIPULANTES — médicos y admin
    // ============================================
    match /tripulantes/{docId} {
      allow read: if isMedicoOrAdmin();
      allow create: if isAdmin();
      allow update: if isMedicoOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
